# Workout Planner - Environment Configuration
# Copy this file to .env and update values as needed
#
# The start script (./scripts/start.sh) will automatically load this file.
# Values can be overridden via command-line arguments.

# Backend API URL (required for full functionality)
# The backend runs from ~/\_Projects/services/workout-planner/
API_BASE_URL=http://localhost:8000

# Auto-authentication (development only)
# Set these to automatically log in when the app starts
WORKOUT_PLANNER_EMAIL=dev@example.com
WORKOUT_PLANNER_PASSWORD=

# Services project location (for auto-starting backend)
# SERVICES_DIR=~/\_Projects/services

# Web server port (for web platform)
WEB_PORT=8080

# Default platform: web, chrome, android, ios, linux
# PLATFORM=web

# Platform-specific API URLs (override API_BASE_URL per platform)
# WEB_API_URL=http://localhost:8000
# ANDROID_API_URL=http://10.0.2.2:8000
# IOS_API_URL=http://localhost:8000

# Feature flags
ENABLE_DEBUG_LOGS=true
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false
