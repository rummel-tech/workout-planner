      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "8.5.0"
    },
    {
      "type": "prometheus",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "2.35.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "graph",
      "targets": [
        {
          "expr": "sum(rate(fitness_request_total[5m])) by (path)",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "title": "99th Percentile Request Latency",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(fitness_request_latency_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "title": "Requests in Progress",
      "type": "graph",
      "targets": [
        {
          "expr": "sum(fitness_requests_in_progress) by (path)",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "graph",
      "targets": [
        {
          "expr": "sum(rate(fitness_error_total[5m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
