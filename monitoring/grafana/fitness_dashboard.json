{
  "id": null,
  "uid": "fitness-ai",
  "title": "Fitness AI Observability",
  "tags": ["fitness", "fastapi", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Total Request Rate (req/s)",
      "id": 1,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "sum(rate(fitness_request_total[5m]))",
          "legendFormat": "all",
          "refId": "A"
        }
      ],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center"},
      "fieldConfig": {"defaults": {"unit": "req/s"}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Error Rate (errors/s)",
      "id": 2,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "sum(rate(fitness_error_total[5m]))",
          "legendFormat": "errors",
          "refId": "A"
        }
      ],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center"},
      "fieldConfig": {"defaults": {"unit": "errors/s"}, "overrides": []}
    },
    {
      "type": "timeSeries",
      "title": "Request Rate by Path/Method",
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "sum by (method, path)(rate(fitness_request_total[5m]))",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "req/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "timeSeries",
      "title": "Error Breakdown by Type",
      "id": 4,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "sum by (type)(rate(fitness_error_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "errors/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "timeSeries",
      "title": "Latency p95 by Path/Method",
      "id": 5,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, method, path)(rate(fitness_request_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{method}} {{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "heatmap",
      "title": "Latency Distribution",
      "id": 6,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "sum by (le)(rate(fitness_request_latency_seconds_bucket[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "req/s"}, "overrides": []},
      "options": {"legend": {"show": true}}
    },
    {
      "type": "timeSeries",
      "title": "Domain Events Rate",
      "id": 7,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "sum by (event)(rate(fitness_domain_event_total[5m]))",
          "legendFormat": "{{event}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "type": "timeSeries",
      "title": "Swim Analytics Computations",
      "id": 8,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "rate(fitness_domain_event_total{event=\"swim_analytics_computed\"}[5m])",
          "legendFormat": "swim_analytics_computed",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}}
    }
    ,{
      "type": "timeSeries",
      "title": "Weekly Plan Events Rate",
      "id": 9,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"weekly_plan_.*\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "stat",
      "title": "Weekly Plans Saved (5m)",
      "id": 10,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum(rate(fitness_domain_event_total{event=\"weekly_plan_saved\"}[5m]))", "legendFormat": "saves", "refId": "A"}
      ],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center"},
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []}
    }
    ,{
      "type": "timeSeries",
      "title": "Daily Plan Events Rate",
      "id": 11,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"daily_plan_.*\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "timeSeries",
      "title": "Goal CRUD Rate",
      "id": 12,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"goal_(created|updated|deleted)\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "timeSeries",
      "title": "Goal Plan Events Rate",
      "id": 13,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"goal_plan_(created|updated|deleted)\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "timeSeries",
      "title": "Auth Login Outcomes",
      "id": 14,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"auth_login_(success|invalid_email|bad_password|inactive)\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "stat",
      "title": "Auth Login Success % (5m)",
      "id": 15,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "(sum(rate(fitness_domain_event_total{event=\"auth_login_success\"}[5m])) / (sum(rate(fitness_domain_event_total{event=~\"auth_login_.*\"}[5m])))) * 100", "legendFormat": "success_pct", "refId": "A"}
      ],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center"},
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []}
    }
    ,{
      "type": "timeSeries",
      "title": "Auth Register Outcomes",
      "id": 16,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"auth_register_(success|email_exists)\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "timeSeries",
      "title": "Auth Refresh Outcomes",
      "id": 17,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"auth_refresh_(success|invalid_token|user_invalid)\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "stat",
      "title": "Active Logouts (5m)",
      "id": 18,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum(rate(fitness_domain_event_total{event=\"auth_logout\"}[5m]))", "legendFormat": "logout", "refId": "A"}
      ],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center"},
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []}
    }
    ,{
      "type": "timeSeries",
      "title": "Chat Session Events",
      "id": 19,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"chat_session_(created|deleted|auto_created)\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "timeSeries",
      "title": "Chat Message Events",
      "id": 20,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"chat_(user_message_saved|assistant_message_saved|exchange_complete|messages_list)\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "timeSeries",
      "title": "Health Metrics CRUD",
      "id": 21,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"health_metrics_(upsert|updated|deleted)\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "stat",
      "title": "Health Samples Ingest Rate (5m)",
      "id": 22,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum(rate(fitness_domain_event_total{event=\"health_samples_ingested\"}[5m]))", "legendFormat": "ingest", "refId": "A"}
      ],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center"},
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []}
    }
    ,{
      "type": "timeSeries",
      "title": "Health Trends Events",
      "id": 23,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"health_trends(_empty)?\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "timeSeries",
      "title": "Strength Events",
      "id": 24,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"strength_metrics_(list|created|deleted)|strength_lift_progress\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "timeSeries",
      "title": "Murph Events",
      "id": 25,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum by (event)(rate(fitness_domain_event_total{event=~\"murph_metrics_(list|created|deleted)|murph_progress(_empty)?\"}[5m]))", "legendFormat": "{{event}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    }
    ,{
      "type": "stat",
      "title": "Readiness Computations (5m)",
      "id": 26,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "sum(rate(fitness_domain_event_total{event=\"readiness_computed\"}[5m]))", "legendFormat": "readiness", "refId": "A"}
      ],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center"},
      "fieldConfig": {"defaults": {"unit": "events/s"}, "overrides": []}
    }
  ],
  "templating": {
    "list": [
      {
        "name": "method",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "refresh": 1,
        "query": "label_values(fitness_request_total, method)",
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      },
      {
        "name": "path",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "refresh": 1,
        "query": "label_values(fitness_request_total, path)",
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "annotations": {"list": []},
  "time": {"from": "now-6h", "to": "now"}
}
