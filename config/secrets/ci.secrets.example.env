# CI (GitHub Actions) Secrets - copy to ci.secrets.env and fill values
# Apple signing
P12_BASE64=
P12_PASSWORD=
MOBILEPROVISION_BASE64=
KEYCHAIN_PASSWORD=

# App Store Connect API (for TestFlight)
APP_STORE_CONNECT_API_KEY=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_KEY_ID=

# AWS (if used in CI for deployments)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Other service tokens (example)
SUPABASE_URL=
SUPABASE_ANON_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
