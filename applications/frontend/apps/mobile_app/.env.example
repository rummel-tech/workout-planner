# Frontend Environment Configuration
# This file is used for web builds. For mobile, use --dart-define

# API Configuration
API_BASE_URL=http://localhost:8000
# For production: https://api.yourdomain.com
# For multi-app development:
#   - workout-planner backend on 8000: http://localhost:8000
#   - other-app backend on 8001: http://localhost:8001

# Application Context
APP_NAME=Workout Planner
APP_CONTEXT=
# Optional: Set to match backend context if using path-based routing

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false
ENABLE_DEBUG_LOGS=true

# Platform-specific API URLs
# Web: Use localhost or actual domain
WEB_API_URL=http://localhost:8000

# Android: Use 10.0.2.2 for emulator, actual IP for device
ANDROID_API_URL=http://10.0.2.2:8000
ANDROID_DEVICE_API_URL=http://192.168.1.100:8000

# iOS: Use localhost for simulator, actual IP for device
IOS_API_URL=http://localhost:8000
IOS_DEVICE_API_URL=http://192.168.1.100:8000
