# Application Configuration
APP_NAME=workout-planner
APP_CONTEXT=
# Optional context path for running alongside other apps (e.g., /workout-api)

# Server Configuration
HOST=0.0.0.0
PORT=8000
# To run alongside other apps, change PORT to avoid conflicts (e.g., 8001, 8002)

# Environment Configuration
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=sqlite:///fitness_dev.db
# For production: postgresql://user:pass@host:5432/dbname
# For multi-app: postgresql://user:pass@host:5432/workout_planner_db

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8081
# Add your frontend URLs here when running in different contexts

# Optional: Redis for caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ENABLED=false
# For multi-app: Use different Redis databases (0-15)
# REDIS_URL=redis://localhost:6379/0  (workout-planner)
# REDIS_URL=redis://localhost:6379/1  (other-app)

# Optional: AI API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
